"""Extended tests for ProteusVariable to improve coverage.

Tests for comparison operators, sequence operations, I/O methods,
and correlation analysis.
"""

import os
import tempfile
from pathlib import Path

import numpy as np
import pandas as pd
import pytest

from pal import maths as pnp
from pal.variables import FreqSevSims, ProteusVariable, StochasticScalar


# =============================================================================
# Comparison Operators Tests
# =============================================================================


def test_comparison_lt_scalars():
    """Test less than operator with scalar values."""
    x = ProteusVariable("dim", {"a": 5, "b": 10, "c": 3})
    y = ProteusVariable("dim", {"a": 3, "b": 15, "c": 3})
    result = x < y
    assert result.values["a"] is True
    assert result.values["b"] is True
    assert result.values["c"] is False


def test_comparison_lt_stochastic():
    """Test less than operator with StochasticScalar values."""
    x = ProteusVariable(
        "dim",
        {
            "a": StochasticScalar([1, 2, 3]),
            "b": StochasticScalar([5, 6, 7]),
        },
    )
    y = ProteusVariable(
        "dim",
        {
            "a": StochasticScalar([2, 2, 2]),
            "b": StochasticScalar([4, 7, 8]),
        },
    )
    result = x < y
    assert (result["a"].values == [True, False, False]).all()
    assert (result["b"].values == [False, True, True]).all()


def test_comparison_le():
    """Test less than or equal operator."""
    x = ProteusVariable("dim", {"a": 5, "b": 10})
    y = ProteusVariable("dim", {"a": 5, "b": 15})
    result = x <= y
    assert result.values["a"] is True
    assert result.values["b"] is True


def test_comparison_gt():
    """Test greater than operator."""
    x = ProteusVariable("dim", {"a": 5, "b": 10})
    y = ProteusVariable("dim", {"a": 3, "b": 15})
    result = x > y
    assert result.values["a"] is True
    assert result.values["b"] is False


def test_comparison_ge():
    """Test greater than or equal operator."""
    x = ProteusVariable("dim", {"a": 5, "b": 10})
    y = ProteusVariable("dim", {"a": 5, "b": 15})
    result = x >= y
    assert result.values["a"] is True
    assert result.values["b"] is False


def test_comparison_eq():
    """Test equality operator."""
    x = ProteusVariable("dim", {"a": 5, "b": 10})
    y = ProteusVariable("dim", {"a": 5, "b": 15})
    result = x == y
    assert result.values["a"] is True
    assert result.values["b"] is False


def test_comparison_ne():
    """Test not equal operator."""
    x = ProteusVariable("dim", {"a": 5, "b": 10})
    y = ProteusVariable("dim", {"a": 5, "b": 15})
    result = x != y
    assert result.values["a"] is False
    assert result.values["b"] is True


def test_comparison_reverse_operators():
    """Test reverse comparison operators."""
    x = ProteusVariable("dim", {"a": 5, "b": 10})
    # Test with scalar on left side (triggers __rlt__, __rgt__, etc.)
    result = 3 < x
    assert result.values["a"] is True
    assert result.values["b"] is True

    result = 15 > x
    assert result.values["a"] is True
    assert result.values["b"] is True


# =============================================================================
# Sequence Operations Tests
# =============================================================================


def test_setitem_by_key():
    """Test setting values by string key."""
    x = ProteusVariable("dim", {"a": 1, "b": 2, "c": 3})
    x["a"] = 10
    assert x["a"] == 10
    assert x["b"] == 2


def test_setitem_by_index():
    """Test setting values by integer index."""
    x = ProteusVariable("dim", {"a": 1, "b": 2, "c": 3})
    x[0] = 10
    # First key should be updated
    assert x[0] == 10


def test_setitem_stochastic():
    """Test setting StochasticScalar values."""
    x = ProteusVariable(
        "dim",
        {"a": StochasticScalar([1, 2, 3]), "b": StochasticScalar([4, 5, 6])},
    )
    new_val = StochasticScalar([7, 8, 9])
    x["a"] = new_val
    assert (x["a"].values == [7, 8, 9]).all()


def test_count():
    """Test counting occurrences of a value."""
    x = ProteusVariable("dim", {"a": 1, "b": 2, "c": 1, "d": 3, "e": 1})
    assert x.count(1) == 3
    assert x.count(2) == 1
    assert x.count(99) == 0


def test_count_stochastic():
    """Test counting with scalar values (not StochasticScalar)."""
    x = ProteusVariable("dim", {"a": 5, "b": 10, "c": 5, "d": 15})
    # Count scalar values
    assert x.count(5) == 2
    assert x.count(10) == 1
    assert x.count(15) == 1


def test_index():
    """Test finding index of a value."""
    x = ProteusVariable("dim", {"a": 1, "b": 2, "c": 3})
    assert x.index(1) == 0
    assert x.index(2) == 1
    assert x.index(3) == 2


def test_index_not_found():
    """Test index raises ValueError when value not found."""
    x = ProteusVariable("dim", {"a": 1, "b": 2, "c": 3})
    with pytest.raises(ValueError, match="not in"):
        x.index(99)


def test_index_with_range():
    """Test index with start and stop parameters."""
    x = ProteusVariable("dim", {"a": 1, "b": 2, "c": 1, "d": 3})
    # Find first occurrence
    assert x.index(1) == 0
    # Find occurrence after index 1
    assert x.index(1, start=1) == 2
    # Search in limited range
    assert x.index(2, start=0, stop=3) == 1


# =============================================================================
# I/O Methods Tests
# =============================================================================


def test_from_csv():
    """Test loading ProteusVariable from CSV file."""
    # Create temporary CSV with proper format (Simulation, dimension, value)
    with tempfile.NamedTemporaryFile(mode="w", suffix=".csv", delete=False) as f:
        f.write("Simulation,category,value\n")
        f.write("0,a,1.5\n")
        f.write("1,a,2.0\n")
        f.write("0,b,3.5\n")
        f.write("1,b,4.0\n")
        temp_path = f.name

    try:
        result = ProteusVariable.from_csv(temp_path, "category", "value", "Simulation")
        assert result.dim_name == "category"
        assert len(result) == 2
        # Values should be StochasticScalar
        assert isinstance(result["a"], StochasticScalar)
        assert isinstance(result["b"], StochasticScalar)
    finally:
        os.unlink(temp_path)


def test_from_csv_with_dim_name():
    """Test from_csv with custom dimension name."""
    with tempfile.NamedTemporaryFile(mode="w", suffix=".csv", delete=False) as f:
        f.write("Simulation,region,loss\n")
        f.write("0,north,100\n")
        f.write("0,south,200\n")
        temp_path = f.name

    try:
        result = ProteusVariable.from_csv(temp_path, "region", "loss", "Simulation")
        assert result.dim_name == "region"
        assert len(result) == 2
    finally:
        os.unlink(temp_path)


def test_from_dict():
    """Test creating ProteusVariable from dictionary."""
    data = {"x": [10, 20, 30], "y": [20, 30, 40], "z": [30, 40, 50]}
    result = ProteusVariable.from_dict(data)
    assert result.dim_name == "Dim1"
    # from_dict creates StochasticScalar values
    assert isinstance(result["x"], StochasticScalar)
    assert isinstance(result["y"], StochasticScalar)
    assert isinstance(result["z"], StochasticScalar)


def test_from_dict_with_arrays():
    """Test from_dict with list arrays."""
    data = {"a": [1.0, 2.0, 3.0], "b": [4.0, 5.0, 6.0]}
    result = ProteusVariable.from_dict(data)
    # from_dict creates StochasticScalar, not raw arrays
    assert isinstance(result["a"], StochasticScalar)
    assert (result["a"].values == [1.0, 2.0, 3.0]).all()


def test_from_series():
    """Test creating ProteusVariable from pandas Series."""
    series = pd.Series({"alpha": 1.0, "beta": 2.0, "gamma": 3.0})
    result = ProteusVariable.from_series(series)
    # from_series creates dim_name from series.name or "None"
    assert result.dim_name == "None"
    assert len(result) == 3
    assert result["alpha"] == pytest.approx(1.0)


def test_from_series_with_name():
    """Test from_series uses series name as dim_name."""
    series = pd.Series({"a": 10, "b": 20}, name="custom")
    result = ProteusVariable.from_series(series)
    assert result.dim_name == "custom"


# =============================================================================
# Correlation Matrix Tests
# =============================================================================


def test_correlation_matrix():
    """Test correlation matrix calculation."""
    x = ProteusVariable(
        "dim",
        {
            "a": StochasticScalar([1, 2, 3, 4, 5]),
            "b": StochasticScalar([2, 3, 4, 5, 6]),  # Perfectly correlated with a
            "c": StochasticScalar([5, 4, 3, 2, 1]),  # Negatively correlated
        },
    )
    corr = x.correlation_matrix()

    # correlation_matrix returns list[list[float]]
    assert isinstance(corr, list)
    assert len(corr) == 3
    assert all(len(row) == 3 for row in corr)

    # Diagonal should be 1.0 (perfectly correlated with itself)
    assert corr[0][0] == pytest.approx(1.0, abs=0.01)
    assert corr[1][1] == pytest.approx(1.0, abs=0.01)
    assert corr[2][2] == pytest.approx(1.0, abs=0.01)

    # a and b should be highly positively correlated
    assert corr[0][1] == pytest.approx(1.0, abs=0.01)

    # a and c should be negatively correlated
    assert corr[0][2] == pytest.approx(-1.0, abs=0.01)


def test_correlation_matrix_single():
    """Test correlation matrix with single variable."""
    x = ProteusVariable("dim", {"a": StochasticScalar([1, 2, 3, 4, 5])})
    corr = x.correlation_matrix()
    # Returns list[list[float]]
    assert len(corr) == 1
    assert len(corr[0]) == 1
    assert corr[0][0] == pytest.approx(1.0)


def test_correlation_matrix_labels():
    """Test correlation matrix with labeled variables."""
    x = ProteusVariable(
        "losses",
        {
            "fire": StochasticScalar([1, 2, 3]),
            "flood": StochasticScalar([2, 3, 4]),
        },
    )
    corr = x.correlation_matrix()
    # Matrix should be 2x2 for 2 variables (returns list)
    assert len(corr) == 2
    assert len(corr[0]) == 2


# =============================================================================
# Additional Edge Cases
# =============================================================================


def test_neg_operator():
    """Test negation operator."""
    x = ProteusVariable("dim", {"a": 5, "b": -3, "c": 0})
    result = -x
    assert result["a"] == -5
    assert result["b"] == 3
    assert result["c"] == 0


def test_pow_operator():
    """Test power operator."""
    x = ProteusVariable("dim", {"a": 2, "b": 3})
    result = x**2
    assert result["a"] == 4
    assert result["b"] == 9


def test_rpow_operator():
    """Test reverse power operator."""
    x = ProteusVariable("dim", {"a": 2, "b": 3})
    result = 2**x
    assert result["a"] == 4
    assert result["b"] == 8


def test_contains():
    """Test __contains__ method."""
    x = ProteusVariable("dim", {"a": 1, "b": 2, "c": 3})
    assert 1 in x
    assert 2 in x
    assert 99 not in x


def test_reversed():
    """Test __reversed__ method."""
    x = ProteusVariable("dim", {"a": 1, "b": 2, "c": 3})
    reversed_list = list(reversed(x))
    # Should reverse the order of values
    assert len(reversed_list) == 3
    assert reversed_list[0] == 3
    assert reversed_list[1] == 2
    assert reversed_list[2] == 1


def test_get_value_at_sim_with_index():
    """Test getting values at specific simulation index."""
    x = ProteusVariable(
        "dim",
        {
            "a": StochasticScalar([10, 20, 30]),
            "b": StochasticScalar([40, 50, 60]),
        },
    )
    result = x.get_value_at_sim(1)
    assert result["a"] == 20
    assert result["b"] == 50


def test_array_protocol():
    """Test numpy array protocol for scalar values."""
    x = ProteusVariable("dim", {"a": 1, "b": 2, "c": 3})
    arr = np.array(x)
    assert len(arr) == 3
    assert (arr == [1, 2, 3]).all()


def test_len():
    """Test __len__ method."""
    x = ProteusVariable("dim", {"a": 1, "b": 2, "c": 3})
    assert len(x) == 3

    empty = ProteusVariable("dim", {})
    assert len(empty) == 0
